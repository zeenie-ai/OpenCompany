{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/canvas/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icons/**",
              "components/panels/**",
              "ui_kits/machinaos/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActionButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:intent|iconOnly|children|key|ref|className|style|children)$/]",
        "message": "<ActionButton> doesn't accept that prop. Declared props: intent, iconOnly, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActionButton'] > JSXAttribute[name.name='intent'] > Literal[value!=/^(?:run|stop|save|config|secret|tools)$/]",
        "message": "<ActionButton> intent must be one of 'run' | 'stop' | 'save' | 'config' | 'secret' | 'tools'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ApiKeyInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|onChange|onSave|onDelete|placeholder|loading|isStored|disabled|saveLabel|savedLabel|style|key|ref|className|style|children)$/]",
        "message": "<ApiKeyInput> doesn't accept that prop. Declared props: value, defaultValue, onChange, onSave, onDelete, placeholder, loading, isStored, disabled, saveLabel, savedLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|color|size|square|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, color, size, square, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|mono|color|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, mono, color, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|outline|accent)$/]",
        "message": "<Badge> variant must be one of 'default' | 'secondary' | 'outline' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|outline|secondary|ghost|destructive|link)$/]",
        "message": "<Button> variant must be one of 'default' | 'outline' | 'secondary' | 'ghost' | 'destructive' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|default|lg|icon|icon-sm)$/]",
        "message": "<Button> size must be one of 'sm' | 'default' | 'lg' | 'icon' | 'icon-sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|selected|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, selected, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|time|children|style|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: role, time, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:user|agent)$/]",
        "message": "<ChatBubble> role must be one of 'user' | 'agent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|label|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CollapsibleSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|defaultCollapsed|collapsed|onToggle|children|style|key|ref|className|style|children)$/]",
        "message": "<CollapsibleSection> doesn't accept that prop. Declared props: title, defaultCollapsed, collapsed, onToggle, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComponentItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|name|description|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ComponentItem> doesn't accept that prop. Declared props: icon, name, description, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|badge|tone|blockLabel|data|onCopy|style|key|ref|className|style|children)$/]",
        "message": "<DataCard> doesn't accept that prop. Declared props: title, badge, tone, blockLabel, data, onCopy, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|error|warning)$/]",
        "message": "<DataCard> tone must be one of 'success' | 'error' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|hint|action|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, hint, action, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|wrapperStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon, wrapperStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kbd'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Kbd> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:time|tone|children|style|key|ref|className|style|children)$/]",
        "message": "<LogLine> doesn't accept that prop. Declared props: time, tone, children, style."
      },

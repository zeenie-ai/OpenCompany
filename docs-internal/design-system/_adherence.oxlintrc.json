      {
        "selector": "JSXOpeningElement[name.name='PanelModal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|titleIcon|headerActions|children|onClose|maxWidth|maxHeight|inline|style|key|ref|className|style|children)$/]",

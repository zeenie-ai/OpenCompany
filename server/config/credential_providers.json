  "_description": "Credential provider catalogue. Loaded by server/services/credential_registry.py at startup; served to clients via the get_credential_catalogue WebSocket handler. Supports `extends` inheritance with array-merge-by-key semantics (see credential_registry.resolve_extends). `_abstract: true` entries are resolved but excluded from get_all_providers(). Color tokens are resolved client-side via the theme helper.",

  "categories": {
    "ai": { "label": "AI Providers", "order": 1 },
    "social": { "label": "Social Media", "order": 2 },
    "productivity": { "label": "Productivity", "order": 3 },

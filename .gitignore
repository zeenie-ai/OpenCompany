# Build artifacts
# =============================================================================
build/
*.tgz
*.exe
*.dll
*.so
*.dylib

# =============================================================================
# Python
# =============================================================================
.venv/
venv/
*.egg-info/
.eggs/

# uv (Python package manager)
uv.lock
server/uv.lock
# .python-version at the repo root IS tracked -- it's the project-wide
# toolchain pin (read by uv, pyenv, asdf, AND ``setup-python`` via
# python-version-file: in our GitHub Actions workflows). Per-developer
# overrides live in server/.python-version (still ignored).
server/.python-version

# =============================================================================
# pnpm
# =============================================================================
pnpm-store/
.pnpm-debug.log

# =============================================================================
# Temporary and cache files
# =============================================================================
*.tmp
*.temp
.cache/
*.cache

# =============================================================================
# Claude Code configuration + per-workflow runtime data
# =============================================================================
# Claude Code's local config / session state / scheduled tasks.
.claude/
# MachinaOs runtime root (`server/core/paths.py::machina_root`). Holds
# claude/, workspaces/, whatsapp/, credentials.db, workflow.db — every
# machine-local artefact. Override path via `DATA_DIR` env var in
# `.env` (default is `~/.machina`, the user home dir; not normally
# present at the repo root). The `workflows/` subtree is the lone
# exception — it ships shipped example seeds (auto-imported on first
# launch by ``services.example_loader``), so it stays tracked.
/.machina/*
!/.machina/workflows/
# Legacy data dir from the pre-cutover layout. Operators upgrading
# from older releases either set `DATA_DIR=data` to keep the old
# layout or `mv` the contents to `~/.machina/` manually.
/data/
# Patch archive left behind by `git format-patch` during one-off
# merges (see ../.merge-archive cleanup commits). Never committed.
.merge-archive/

# Test side-effect dir from conftest's core.paths stub
# (server/core/paths.py). conftest points the stub's machina_root
# at this dir so plugin module imports don't touch the real user
# home during tests. Re-created on each test run.
server/tests/_test_machina_root/

# =============================================================================
# Documentation (docs-MachinaOs is a separate GitHub project)
# =============================================================================
docs-MachinaOs/

# =============================================================================
# Experiments (work in progress)
# =============================================================================
server/experiments/

    "telegram": {
      "name": "Telegram Bot",
      "category": "social",
      "category_label": "Social Media",
      "color": "theme.categoryChat",
      "kind": "oauth",
      "icon_ref": "/api/schemas/credentials/telegram/icon",
      "status_hook": "telegram",
      "_stored_check_note": "Telegram uses status_hook for runtime connection state but stores the bot token via api_key (under the canonical 'telegram' id), not OAuth. Override the catalogue handler's default get_oauth_tokens(status_hook) lookup so the connected/stored badge reflects bot-token presence.",
      "stored_check": {
        "type": "api_key",
        "key": "telegram"
      },
      "ws": {
        "login": "telegram_connect",
        "logout": "telegram_disconnect",
        "status": "telegram_status"
      },
      "fields": [
        {
          "key": "telegram",
          "label": "Bot Token",
          "type": "password",
          "secret": true,
          "placeholder": "123456789:ABCdefGHIjklMNOpqrSTUvwxYZ",
          "required": true
        },
        {
          "key": "telegram_owner_chat_id",
          "label": "Your Chat ID (optional)",
          "type": "text",
          "secret": false,
          "placeholder": "e.g. 123456789 — DM @userinfobot to get yours",
          "required": false,
          "help": "Set this to make telegramSend(recipient_type=self) route to your account immediately. If left blank, the bot auto-captures it from the first private DM you send after connecting."
        }
      ],
      "instructions": "Get a bot token from @BotFather on Telegram. To use the 'Self' recipient on telegramSend, either fill in your Chat ID below or DM your bot once after connecting."
    },


        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|footer|onClose|width|inline|style|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, title, children, footer, onClose, width, inline, style."

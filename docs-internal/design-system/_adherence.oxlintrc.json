      {
        "selector": "JSXOpeningElement[name.name='ModeToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|onChange|style|key|ref|className|style|children)$/]",
        "message": "<ModeToggle> doesn't accept that prop. Declared props: mode, onChange, style."

      {
        "selector": "JSXOpeningElement[name.name='ModeToggle'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:normal|dev)$/]",
        "message": "<ModeToggle> mode must be one of 'normal' | 'dev'."

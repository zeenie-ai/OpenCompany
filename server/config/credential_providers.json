    "ollama": {
      "_description": "Local Ollama server. The single field stores a base URL; the backend's _LocalLLM credential class returns a placeholder api_key, and execute_chat reads `{provider}_proxy` to override base_url via the existing OpenAI-style auth-delegation path. No `extends` — the field shape diverges from the cloud `_ai_base` template.",
      "name": "Ollama",
      "category": "ai",
      "category_label": "AI Providers",
      "color": "dracula.foreground",
      "kind": "apiKey",
      "icon_ref": "lobehub:ollama",
      "has_defaults": true,
      "fields": [
        {
          "key": "ollama_proxy",
          "label": "Base URL",
          "type": "string",
          "placeholder": "http://localhost:11434/v1",
          "default": "http://localhost:11434/v1",
          "required": true
        }
      ],
      "instructions": "Run `ollama serve` locally (or point Base URL at any reachable Ollama server). API key is not needed — the credential resolver supplies the documented `ollama` placeholder."
    },

    "lmstudio": {
      "_description": "Local LM Studio server (OpenAI-compatible /v1). Same shape as ollama: single base-URL field stored as `lmstudio_proxy`.",

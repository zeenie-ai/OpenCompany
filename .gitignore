# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# npm-generated lock file. This project uses pnpm (canonical lock:
# ``pnpm-lock.yaml``, tracked). Source checkouts are gated to pnpm
# by ``scripts/preinstall.js``; ``package-lock.json`` only appears
# if npm runs outside the workspace. Keep it out of commits.
package-lock.json

# =============================================================================
# SECURITY - Credentials and Secrets (NEVER COMMIT)
# =============================================================================
# Environment variables (contain API keys, secrets)
.env
.env.*
!.env.template
!.env.example
server/.env
server/.env.*
!server/.env.template
!server/.env.example

# API Keys and Credentials
**/credentials.json
**/secrets.json
**/apikeys.json
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx

# WhatsApp RPC is now an npm dependency (@anthropic/whatsapp-rpc)
# Session data is stored in node_modules/@anthropic/whatsapp-rpc/data/

# =============================================================================

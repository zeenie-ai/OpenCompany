# Service Ports (used by start.js, vite, and docker-compose)
VITE_CLIENT_PORT=3000
PYTHON_BACKEND_PORT=3010
NODEJS_EXECUTOR_PORT=3020
WHATSAPP_RPC_PORT=9400
REDIS_PORT=6379

# Server Configuration
HOST=127.0.0.1
PORT=3010
DEBUG=false
WORKERS=1

# Security (Development keys - MUST CHANGE FOR PRODUCTION)
SECRET_KEY=dev-secret-key-12345678901234567890123456789012
API_KEY_ENCRYPTION_KEY=dev-encryption-key-12345678901234567890123456

# Authentication
# VITE_AUTH_ENABLED: "true" (require login) or "false" (bypass authentication)
VITE_AUTH_ENABLED=false
# AUTH_MODE: "single" (local deploy - first user is owner) or "multi" (cloud - open registration)
AUTH_MODE=single
JWT_SECRET_KEY=dev-jwt-secret-key-12345678901234567890
JWT_EXPIRE_MINUTES=10080
JWT_COOKIE_NAME=machina_token
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=lax

# CORS Configuration - Allow all common dev ports
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:3003","http://localhost:3004","http://localhost:3005","http://localhost:3006","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3002","http://127.0.0.1:3003","http://127.0.0.1:3004","http://127.0.0.1:3005","http://127.0.0.1:3006","http://localhost:5173"]

# Database Configuration
# SQLite DB filename. Resolved under DATA_DIR by
# ``Settings._resolve_under_data`` — same pattern as ``temporal.db``
# and ``credentials.db`` so dev mode's DATA_DIR=.machina moves all
# three together. The SQLAlchemy URL is composed at runtime by
# ``Settings.database_url`` (sqlite+aiosqlite:///<abspath>).
WORKFLOW_DB_FILENAME=workflow.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Cache Configuration (Disabled for development)
REDIS_ENABLED=false
CACHE_TTL=300

# Temporal Configuration
# Enable for durable workflow execution with automatic retries.
# Backed by ``temporal server start-dev`` against a SQLite db at
# ``TEMPORAL_SQLITE_PATH``. The official ``temporal`` CLI is downloaded
# by pooch from https://temporal.download/cli/archive/latest on
# ``machina build`` (or first ``machina start`` if build was skipped).
TEMPORAL_ENABLED=true
TEMPORAL_SERVER_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=machina-tasks
TEMPORAL_PER_TYPE_DISPATCH=true
TEMPORAL_AGENT_WORKFLOW_ENABLED=true
# Wave 16: per-queue activity routing. When true, a TemporalWorkerPool
# starts one activity-only Worker per plugin-declared task queue
# (ai-heavy / browser / code-exec / rest-api / messaging / ...) and
# per-type activities route to their specialised queue instead of the
# single 100-slot pool on machina-tasks. Rollback channel: set false +
# restart — activities route back to the manager worker unchanged.
TEMPORAL_WORKER_POOL_ENABLED=false
# Deployment topology hint: local (dev laptop; sleeps; halved per-queue
# concurrency) | cloud (machina deploy VM) | self_hosted. Drives worker
# identity strings in the Temporal Web UI and per-mode concurrency
# defaults. Explicit TEMPORAL_<QUEUE>_CONCURRENCY overrides always win.
DEPLOYMENT_MODE=local
# gRPC frontend port the CLI dev server binds (``--port``). Default per
# https://docs.temporal.io/references/configuration.
TEMPORAL_FRONTEND_GRPC_PORT=7233
# Web UI port (``--ui-port``). ``temporal server start-dev`` defaults
# this to ``--port + 1000``; we override to 8080 to match the
# historical MachinaOS port (kept for muscle memory + bookmarks).
# Browse to http://<host>:<TEMPORAL_UI_PORT>/.
TEMPORAL_UI_PORT=8080
# SQLite db file ``temporal server start-dev --db-filename`` opens.
# Relative to DATA_DIR (= ~/.machina/) unless absolute. Flat under
# DATA_DIR like ``credentials.db`` / ``workflow.db``. History is
# always preserved across restarts (Temporal UI keeps showing every
# workflow that ever ran); see ``TEMPORAL_TERMINATE_RUNNING_ON_STARTUP``
# below for the resumption knob.
TEMPORAL_SQLITE_PATH=temporal.db
# On server boot, terminate every workflow still in ``Running`` state.
# History is preserved (workflows show as ``Terminated`` in the UI,
# NOT deleted) but resumption is disabled, because MachinaOS's
# ``DeploymentManager`` has no boot-time reconcile against Temporal
# Visibility yet — resumed workflows would otherwise keep executing
# but be invisible to the MachinaOS UI. Flip to ``false`` once the
# reconcile lands to re-enable durable resumption.
TEMPORAL_TERMINATE_RUNNING_ON_STARTUP=true
# Graceful shutdown window for the Temporal child process.
TEMPORAL_GRACEFUL_SHUTDOWN_SECONDS=30
# Supervisor readiness-probe window. The CLI binary may need to
# download (~114 MB zip) on first ``machina start`` if ``machina build``
# didn't pre-cache it.
TEMPORAL_SERVER_READY_TIMEOUT_SECONDS=120

# --- Startup resilience (server-ready-before-workers) ---
# After the gRPC port binds, the client polls the WorkflowService gRPC
# health check until it reports SERVING before starting the worker /
# visibility sweep (the documented readiness probe; see
# https://docs.temporal.io/troubleshooting/deadline-exceeded-error).
# Bounded — the unbounded layer is main.py's 3s reconnect loop.
TEMPORAL_HEALTH_CHECK_ATTEMPTS=5
TEMPORAL_HEALTH_CHECK_DELAY_SECONDS=0.5
TEMPORAL_HEALTH_CHECK_TIMEOUT_SECONDS=2.0
# The boot-time terminate-running sweep issues a Visibility query that
# races shard acquisition ("shard status unknown"). Retry it a few times
# (linear backoff = attempt x base) before giving up for that boot.
TEMPORAL_SWEEP_ATTEMPTS=4
TEMPORAL_SWEEP_BACKOFF_SECONDS=0.5
# The embedded worker self-restarts on a transient crash (the Temporal
# worker shuts down on a poll failure rather than auto-retrying). Backoff
# doubles from base up to max between restarts.
TEMPORAL_WORKER_RESTART_BACKOFF_SECONDS=1.0
TEMPORAL_WORKER_RESTART_BACKOFF_MAX_SECONDS=30.0

# Wave 12 event framework. ``true`` (default) routes trigger events
# through TriggerListenerWorkflow + Temporal Signal fan-out for the
# 8 canary-registered trigger types (webhook, chat, task, telegram,
# whatsapp, gmail, cron, email). Flip to ``false`` to roll back to
# the legacy event_waiter path -- see docs-internal/event_framework.md.
EVENT_FRAMEWORK_ENABLED=true

# Memory compaction. ``true`` (default) auto-compacts agent
# conversation memory when cumulative tokens exceed the model's
# context-window threshold. Per-session overrides via the UI.
COMPACTION_ENABLED=true

# Compaction trigger threshold as a fraction of the model's context
# window (0.05 - 0.99). 0.8 = compact when cumulative tokens hit 80%.
# Per-user overrides via the UserSettings row (Settings tab).
COMPACTION_RATIO=0.8

# Agent loop hard step cap. AI Agent + Chat Agent stop the LLM/tool
# iteration loop after this many rounds and return a truncation note.
# Per-user overrides via the UserSettings row (Settings tab).
AGENT_RECURSION_LIMIT=200

# Browser automation (agent-browser CLI). Each distinct browser
# session maps to one Chrome instance. BROWSER_MAX_INSTANCES caps
# concurrent instances — when a new session would exceed it, the
# least-recently-used session is closed first. BROWSER_IDLE_TIMEOUT_MS
# makes the agent-browser daemon close its browser after that many
# milliseconds without commands (0 disables).
BROWSER_MAX_INSTANCES=3
BROWSER_IDLE_TIMEOUT_MS=600000

# Dead-letter queue for failed workflow executions. Off by default.
DLQ_ENABLED=false

# Data directory (base for all persistent storage: DBs, workspaces,
# workflows, claude state). User-home rooted by default — same
# convention claude code itself uses (`~/.claude/`), Stripe
# (`~/.config/stripe/`), ngrok (`~/.ngrok2/`). Survives `rm -rf` of
# the repo and lets multiple checkouts share state.
#
# Resolution rules (`server/core/paths.py::machina_root`):
#   - `~/...`  → user home (cross-platform via Path.expanduser)
#   - absolute → used verbatim
#   - relative → resolved under repo root (back-compat)
#
# Set to `.machina` (or `data`) if you want repo-local behaviour
# instead. Pre-cutover layouts (`<repo>/data/`, `<repo>/workflows/`)
# do NOT auto-migrate — see `server/core/paths.py` for the manual
# `mv` checklist if you're upgrading from an older release.
DATA_DIR=~/.machina

# Per-workflow workspace (nodes save files here, resolved under DATA_DIR)
WORKSPACE_BASE_DIR=workspaces

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Rate Limiting (Relaxed for development)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# Service Timeouts (Extended for debugging)
AI_TIMEOUT=60
AI_MAX_RETRIES=1
AI_RETRY_DELAY=0.5

MAPS_TIMEOUT=30

# Health Check
HEALTH_CHECK_INTERVAL=60

# Cleanup Configuration (for long-running daemon)
CLEANUP_ENABLED=true
CLEANUP_INTERVAL=3600
CLEANUP_LOGS_MAX_COUNT=1000
CLEANUP_CACHE_MAX_AGE_HOURS=24

# Feature Toggles
WS_LOGGING_ENABLED=true


      "instructions": "Start the LM Studio local server from the Developer tab. API key is not required."
    },

    "_cli_base": {
      "_abstract": true,
      "category": "ai",
      "category_label": "AI Providers",
      "kind": "oauth",
      "_kind_doc": "Stripe-style CLI-managed auth: OpenCompany spawns `<provider> login` from a per-provider WS handler; each CLI manages credentials in its isolated directory under <DATA_DIR>, and we write a synthetic marker OAuth token on success so the catalogue's `stored` flag flips. OAuthConnect.tsx renders empty fields because `fields=[]` (see OAuthConnect.tsx:42 — the documented Stripe-style fieldless-CLI case). Each child sets its own `ws.login`/`ws.logout` so the handler name encodes the provider (Twitter / Google / Stripe convention — frontend dispatches `{}` payload).",
      "fields": []
    },

